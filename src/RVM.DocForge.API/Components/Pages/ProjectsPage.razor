@page "/projects"
@using RVM.DocForge.API.Services
@using RVM.DocForge.Domain.Entities
@using RVM.DocForge.Domain.Interfaces
@inject IDocumentationProjectRepository ProjectRepo
@inject IProjectSnapshotRepository SnapshotRepo
@inject GitCloneService CloneService

<h1>Projects</h1>

<div class="toolbar">
    <button class="btn btn-primary" @onclick="ToggleCreateForm">+ New Project</button>
</div>

@if (_showForm)
{
    <div class="form-card">
        <h3>New Project</h3>
        <div class="form-group">
            <label>Name</label>
            <input class="form-input" @bind="_newName" />
        </div>

        <div class="source-toggle">
            <button class="toggle-btn @(_useUrl ? "" : "active")" @onclick="() => _useUrl = false">Local Path</button>
            <button class="toggle-btn @(_useUrl ? "active" : "")" @onclick="() => _useUrl = true">Git Repository</button>
        </div>

        @if (_useUrl)
        {
            <div class="form-group">
                <label>Git Repository URL</label>
                <input class="form-input" @bind="_newGitUrl" placeholder="https://github.com/user/repo.git" />
            </div>
        }
        else
        {
            <div class="form-group">
                <label>Repository Path</label>
                <input class="form-input" @bind="_newRepoPath" placeholder="C:\path\to\repo" />
            </div>
        }

        <div class="form-group">
            <label>Description (optional)</label>
            <input class="form-input" @bind="_newDescription" />
        </div>

        @if (!string.IsNullOrEmpty(_formError))
        {
            <p class="error">@_formError</p>
        }

        <div class="form-actions">
            <button class="btn btn-primary" @onclick="CreateProjectAsync" disabled="@_creating">
                @(_creating ? (_useUrl ? "Cloning..." : "Creating...") : "Create")
            </button>
            <button class="btn btn-secondary" @onclick="ToggleCreateForm">Cancel</button>
        </div>
    </div>
}

@if (!_loaded)
{
    <div class="loading">Loading projects...</div>
}
else
{
    @if (_projects.Count == 0)
    {
        <div class="empty-state">No projects found. Create one above or register via the API.</div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Source</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Last Analyzed</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in _projects.OrderByDescending(p => p.CreatedAt))
                {
                    <tr>
                        <td>@project.Name</td>
                        <td>
                            @if (!string.IsNullOrEmpty(project.GitRemoteUrl))
                            {
                                <span class="badge">Git</span>
                            }
                            else
                            {
                                <span class="badge">Local</span>
                            }
                        </td>
                        <td><span class="badge">@project.Status</span></td>
                        <td>@project.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>@(project.LastAnalyzedAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                        <td>
                            <button class="btn-sm" @onclick="() => SelectProject(project)">
                                @(_selectedProject?.Id == project.Id ? "Hide" : "Snapshots")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (_selectedProject is not null)
    {
        <div class="detail-card">
            <h2>Snapshots for @_selectedProject.Name</h2>

            @if (_loadingSnapshots)
            {
                <div class="loading">Loading snapshots...</div>
            }
            else if (_snapshots.Count == 0)
            {
                <div class="empty-state">No snapshots yet. Run an analysis to generate the first snapshot.</div>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Analyzed At</th>
                            <th>Projects</th>
                            <th>Classes</th>
                            <th>Endpoints</th>
                            <th>Entities</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var snapshot in _snapshots.OrderByDescending(s => s.AnalyzedAt))
                        {
                            <tr>
                                <td>@snapshot.AnalyzedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@snapshot.ProjectCount</td>
                                <td>@snapshot.TotalClasses</td>
                                <td>@snapshot.TotalEndpoints</td>
                                <td>@snapshot.TotalEntities</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
}

@code {
    private bool _loaded;
    private bool _loadingSnapshots;
    private List<DocumentationProject> _projects = [];
    private DocumentationProject? _selectedProject;
    private List<ProjectSnapshot> _snapshots = [];

    // Create form
    private bool _showForm;
    private bool _useUrl;
    private bool _creating;
    private string _newName = "";
    private string _newRepoPath = "";
    private string _newGitUrl = "";
    private string _newDescription = "";
    private string? _formError;

    protected override async Task OnInitializedAsync()
    {
        _projects = await ProjectRepo.GetAllAsync();
        _loaded = true;
    }

    private void ToggleCreateForm()
    {
        _showForm = !_showForm;
        _formError = null;
    }

    private async Task CreateProjectAsync()
    {
        if (string.IsNullOrWhiteSpace(_newName))
        {
            _formError = "Name is required.";
            return;
        }

        _creating = true;
        _formError = null;
        StateHasChanged();

        try
        {
            string repoPath;

            if (_useUrl)
            {
                if (string.IsNullOrWhiteSpace(_newGitUrl))
                {
                    _formError = "Git URL is required.";
                    return;
                }
                repoPath = CloneService.Clone(_newGitUrl);
            }
            else
            {
                if (string.IsNullOrWhiteSpace(_newRepoPath))
                {
                    _formError = "Repository path is required.";
                    return;
                }
                repoPath = _newRepoPath;
            }

            var project = new DocumentationProject
            {
                Name = _newName,
                RepositoryPath = repoPath,
                GitRemoteUrl = _useUrl ? _newGitUrl : null,
                Description = string.IsNullOrWhiteSpace(_newDescription) ? null : _newDescription
            };

            await ProjectRepo.AddAsync(project);
            _projects = await ProjectRepo.GetAllAsync();
            _showForm = false;
            _newName = "";
            _newRepoPath = "";
            _newGitUrl = "";
            _newDescription = "";
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _creating = false;
        }
    }

    private async Task SelectProject(DocumentationProject project)
    {
        if (_selectedProject?.Id == project.Id)
        {
            _selectedProject = null;
            _snapshots = [];
            return;
        }

        _selectedProject = project;
        _loadingSnapshots = true;
        _snapshots = await SnapshotRepo.GetByProjectIdAsync(project.Id);
        _loadingSnapshots = false;
    }
}
